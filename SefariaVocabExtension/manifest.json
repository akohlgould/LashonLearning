{
  "manifest_version": 3,
  "name": "Flashcard Word Grabber",
  "version": "1.2",
  "permissions": ["storage", "contextMenus"],
  "action": {
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  },
  "background": {
    "service_worker": "background.js"
  }
}