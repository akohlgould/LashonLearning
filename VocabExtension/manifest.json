{
  "manifest_version": 3,
  "name": "Flashcard Word Grabber",
  "key": "",
  "version": "1.0",
  "permissions": ["storage", "contextMenus"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flashcard Word Grabber"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sefaria.org/*", "*://*.sefaria.org.il/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://akohlgould.github.io/*"
    ]
  }
}
