{
  "manifest_version": 3,
  "name": "Lashon Learning",
  "description": "Quickly collect Hebrew vocabulary from Sefaria and export flashcards\nwith definitions and verses.",
  "short_name": "Lashon",
  "key": "",
  "version": "1.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "contextMenus"],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "Lashon Learning"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sefaria.org/*", "*://*.sefaria.org.il/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["*://*.sefaria.org/*", "*://*.sefaria.org.il/*"]
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost/*", "https://akohlgould.github.io/*"]
  }
}
